generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(cuid())
  dni                    String?  @unique
  email                  String   @unique
  password               String
  nombre                 String
  apellido               String
  role                   String   @default("empleado")
  areaId                 String?
  activo                 Boolean  @default(true)
  necesitaCambioPassword Boolean  @default(false) @map("necesita_cambio_password")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relaciones
  area                    Area?              @relation("AreaEmpleados", fields: [areaId], references: [id])
  areaJefe                Area[]             @relation("AreaJefe")
  evaluacionesRecibidas   Evaluacion[]       @relation("EmpleadoEvaluado")
  evaluacionesCreadas     Evaluacion[]       @relation("Evaluador")
  ordenesTrabajoRecibidas OrdenTrabajo[]     @relation("EmpleadoOrden")
  ordenesTrabajoCreadas   OrdenTrabajo[]     @relation("CreadorOrden")
  revisionesRealizadas    RevisionJefe[]
  solicitudesTarea        SolicitudTarea[]   @relation("EmpleadoSolicitud")
  solicitudesEdicion      SolicitudEdicion[] @relation("SolicitanteEdicion")
  alertas                 Alerta[]           @relation("AlertasEmpleado")
  puestoId                String?            @map("puesto_id")
  puesto                  Puesto?            @relation("EmpleadoPuesto", fields: [puestoId], references: [id], onDelete: SetNull)
  sessions                Session[]
  evidenciaKPIs           EvidenciaKPI[]
  evidenciasKPISubidas    EvidenciaKPI[]     @relation("EvidenciasKPIEmpleado")
  evidenciasKPIRevisadas  EvidenciaKPI[]     @relation("EvidenciasKPIRevisor")
  revisoresAsignados      RevisorAsignado[]  @relation("EmpleadoRevisor")
  asignadoComoRevisor     RevisorAsignado[]  @relation("RevisorDeEmpleado")

  @@index([areaId])
  @@index([email])
  @@index([role])
}

model Area {
  id              String  @id @default(uuid())
  nombre          String
  descripcion     String?
  jefeId          String? @map("jefe_id")
  promedioGlobal  Float   @default(0) @map("promedio_global")
  totalKpis       Int     @default(0) @map("total_kpis")
  kpisRojos       Int     @default(0) @map("kpis_rojos")
  porcentajeRojos Float   @default(0) @map("porcentaje_rojos")
  nivelRiesgo     String  @default("BAJO") @map("nivel_riesgo")
  ranking         Int     @default(0)
  comentarioRRHH  String? @map("comentario_rrhh")
  accionSugerida  String? @map("accion_sugerida")
  responsable     String?
  activa          Boolean @default(true)

  // ⭐ NUEVA: Auto-referencia para jerarquía
  areaPadreId String? @map("area_padre_id")
  areaPadre   Area?   @relation("AreaJerarquia", fields: [areaPadreId], references: [id], onDelete: SetNull)
  subAreas    Area[]  @relation("AreaJerarquia")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones existentes
  jefe           User?          @relation("AreaJefe", fields: [jefeId], references: [id], onDelete: SetNull)
  empleados      User[]         @relation("AreaEmpleados")
  kpis           KPI[]
  evaluaciones   Evaluacion[]
  ordenesTrabajo OrdenTrabajo[]
  alertas        Alerta[]
  puestos        Puesto[]

  @@map("areas")
}

model KPI {
  id          String  @id @default(cuid())
  key         String  @unique
  area        String
  areaId      String
  indicador   String
  descripcion String? @db.Text

  // Configuración de cálculo automático
  tipoCalculo    String // "binario", "division", "conteo", "porcentaje_kpis_equipo", "dashboard_presentado"
  formulaCalculo String @db.Text // JSON con estructura de cálculo

  // Metas
  meta           Float?
  operadorMeta   String? @default(">=") // ">", ">=", "=", "<=", "<"
  tolerancia     Float?
  umbralAmarillo Float?

  // Criticidad
  tipoCriticidad String @default("no_critico") // "critico", "no_critico"

  periodicidad       String
  sentido            String // "Mayor es mejor", "Menor es mejor"
  unidad             String?
  aplicaOrdenTrabajo Boolean  @default(false) @map("aplica_orden_trabajo")
  horasLimiteOrden   Int      @default(0) @map("horas_limite_orden")
  orden              Int      @default(0)
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relaciones
  areaRelacion       Area                @relation(fields: [areaId], references: [id], onDelete: Cascade)
  ordenesTrabajoKPI  OrdenTrabajo[]
  evaluacionDetalles EvaluacionDetalle[]
  puestoId           String?             @map("puesto_id")
  puesto             Puesto?             @relation(fields: [puestoId], references: [id], onDelete: SetNull)
  evidenciaKPIs      EvidenciaKPI[]

  @@index([areaId])
  @@index([activo])
  @@index([puestoId])
  @@index([tipoCalculo])
  @@index([tipoCriticidad])
}

model OrdenTrabajo {
  id         String  @id @default(cuid())
  kpiId      String? // null cuando tipoOrden = 'personalizado'
  empleadoId String
  creadorId  String

  titulo         String
  descripcion    String @db.Text
  cantidadTareas Int // Número de tareas/evidencias requeridas

  // Tipo y estado
  tipoOrden String @default("kpi_sistema") // "kpi_sistema", "orden_empleado"
  status    String @default("pendiente") // "pendiente", "en_proceso", "completada", "vencida", "rechazada", "en_pausa", "cancelada", "aprobada"

  // Fechas
  fechaInicio         DateTime  @default(now())
  fechaLimite         DateTime
  fechaLimiteOriginal DateTime?
  fechaExtendida      DateTime?
  motivoExtension     String?   @db.Text
  fechaCompletada     DateTime?

  // Pausa
  enPausa     Boolean   @default(false)
  motivoPausa String?   @db.Text
  fechaPausa  DateTime?

  // Edición
  requiereAprobacion Boolean @default(false)

  // Cálculo automático
  valoresCalculo    String? @db.Text
  tareasCompletadas Int     @default(0)
  progreso          Float   @default(0) // Porcentaje de avance
  resultadoFinal    Float? // Resultado calculado automáticamente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  kpi                KPI?               @relation(fields: [kpiId], references: [id])
  empleado           User               @relation("EmpleadoOrden", fields: [empleadoId], references: [id])
  creador            User               @relation("CreadorOrden", fields: [creadorId], references: [id])
  tareas             Tarea[]
  revision           RevisionJefe?
  solicitudesTarea   SolicitudTarea[]
  solicitudesEdicion SolicitudEdicion[]
  area               Area?              @relation(fields: [areaId], references: [id])
  areaId             String?

  @@index([kpiId])
  @@index([empleadoId])
  @@index([creadorId])
  @@index([status])
  @@index([fechaLimite])
  @@index([tipoOrden])
}

model Tarea {
  id             String @id @default(cuid())
  ordenTrabajoId String
  descripcion    String @db.Text
  orden          Int // Orden de la tarea (1, 2, 3...)

  completada      Boolean   @default(false)
  fueraDeTiempo   Boolean   @default(false)
  fechaLimite     DateTime? // Heredada de la orden
  fechaCompletada DateTime?

  // Solicitud de tarea adicional
  solicitudAgregar Boolean @default(false)
  aprobadaPorJefe  Boolean @default(false)

  // Intentos de evidencia
  intentosEvidencia Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  evidencias   Evidencia[]

  @@index([ordenTrabajoId])
  @@index([completada])
}

model Evidencia {
  id      String @id @default(cuid())
  tareaId String

  archivoUrl String // URL del archivo en cloud storage
  tipo       String // "imagen", "pdf", "video", "documento"
  nombre     String // Nombre original del archivo
  tamanio    Int? // Tamaño en bytes

  intento Int @default(1) // 1er intento, 2do, etc

  status          String  @default("pendiente_revision") // "pendiente_revision", "aprobada", "rechazada"
  motivoRechazo   String? @db.Text
  esFueraDeTiempo Boolean @default(false)

  // Apelación
  apelacion          String?   @db.Text
  respuestaApelacion String?   @db.Text
  fechaApelacion     DateTime?

  fechaSubida DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  tarea Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@index([tareaId])
  @@index([status])
}

model SolicitudTarea {
  id             String @id @default(cuid())
  ordenTrabajoId String
  empleadoId     String

  descripcion   String @db.Text
  justificacion String @db.Text

  status        String  @default("pendiente") // "pendiente", "aprobada", "rechazada"
  motivoRechazo String? @db.Text

  fechaSolicitud DateTime  @default(now())
  fechaRespuesta DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  empleado     User         @relation("EmpleadoSolicitud", fields: [empleadoId], references: [id])

  @@index([ordenTrabajoId])
  @@index([empleadoId])
  @@index([status])
}

model SolicitudEdicion {
  id             String @id @default(cuid())
  ordenTrabajoId String
  solicitanteId  String

  campoAEditar  String // "fechaLimite", "descripcion", "cantidadTareas"
  valorActual   String @db.Text
  valorNuevo    String @db.Text
  justificacion String @db.Text

  status        String  @default("pendiente") // "pendiente", "aprobada", "rechazada"
  motivoRechazo String? @db.Text

  fechaSolicitud DateTime  @default(now())
  fechaRespuesta DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  solicitante  User         @relation("SolicitanteEdicion", fields: [solicitanteId], references: [id])

  @@index([ordenTrabajoId])
  @@index([solicitanteId])
  @@index([status])
}

model RevisionJefe {
  id             String @id @default(cuid())
  ordenTrabajoId String @unique
  jefeId         String

  status        String // "aprobada", "rechazada"
  motivoRechazo String? @db.Text

  // Retroalimentación
  comentarios  String? @db.Text
  calificacion Int? // Opcional: calificación 1-5 si el KPI lo requiere

  fechaRevision DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  jefe         User         @relation(fields: [jefeId], references: [id])

  @@index([ordenTrabajoId])
  @@index([jefeId])
  @@index([status])
}

model Evaluacion {
  id          String  @id @default(cuid())
  empleadoId  String
  evaluadorId String // Sistema (puede ser ID especial "SISTEMA")
  periodo     String
  tipoPeriodo String?
  anio        Int

  // Cálculo 100% automático
  calculadaAutomaticamente Boolean @default(true)
  promedioGeneral          Float?
  kpisRojos                Int     @default(0)
  porcentajeRojos          Float   @default(0)

  status       String    @default("borrador") // "borrador", "calculada", "cerrada"
  fechaCalculo DateTime?
  fechaCierre  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  empleado  User                @relation("EmpleadoEvaluado", fields: [empleadoId], references: [id])
  evaluador User                @relation("Evaluador", fields: [evaluadorId], references: [id])
  detalles  EvaluacionDetalle[]
  alertas   Alerta[]
  area      Area?               @relation(fields: [areaId], references: [id])
  areaId    String?

  @@unique([empleadoId, periodo, anio])
  @@index([empleadoId])
  @@index([evaluadorId])
  @@index([status])
  @@index([anio])
}

model EvaluacionDetalle {
  id             String  @id @default(cuid())
  evaluacionId   String
  kpiId          String
  ordenTrabajoId String? // Referencia a la orden que generó este resultado

  // Resultados calculados automáticamente
  resultadoNumerico   Float
  resultadoPorcentaje Float?
  brechaVsMeta        Float?
  estado              String? // "verde", "amarillo", "rojo"

  // Metadata del cálculo
  formulaUtilizada String? @db.Text // JSON con los parámetros usados en el cálculo

  meta           Float?
  umbralAmarillo Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  evaluacion Evaluacion @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)
  kpi        KPI        @relation(fields: [kpiId], references: [id])

  @@index([evaluacionId])
  @@index([kpiId])
  @@index([ordenTrabajoId])
  @@index([estado])
}

model Alerta {
  id           String  @id @default(cuid())
  areaId       String
  empleadoId   String?
  evaluacionId String?

  tipo           String // "orden_vencida", "orden_completada", "kpi_critico", "evidencia_rechazada", "evidencia_aprobada", "carga_alta", "solicitud_tarea_pendiente", "solicitud_edicion_pendiente"
  nivel          String // "BAJO", "MEDIO", "ALTO"
  titulo         String
  descripcion    String  @db.Text
  accionSugerida String? @db.Text
  responsable    String?

  status          String    @default("activa") // "activa", "en_proceso", "resuelta"
  fechaDeteccion  DateTime  @default(now())
  fechaResolucion DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  area       Area        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  empleado   User?       @relation("AlertasEmpleado", fields: [empleadoId], references: [id], onDelete: SetNull)
  evaluacion Evaluacion? @relation(fields: [evaluacionId], references: [id], onDelete: SetNull)

  @@index([areaId])
  @@index([empleadoId])
  @@index([evaluacionId])
  @@index([status])
  @@index([nivel])
  @@index([tipo])
}

model Puesto {
  id          String  @id @default(uuid())
  nombre      String
  descripcion String?
  areaId      String  @map("area_id")
  activo      Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  area      Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  empleados User[] @relation("EmpleadoPuesto")
  kpis      KPI[]

  @@unique([nombre, areaId]) // Un puesto único por área
  @@map("puestos")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  accessToken  String   @unique @map("access_token")
  refreshToken String   @unique @map("refresh_token")
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  expiresAt    DateTime @map("expires_at") // Para refresh token (1 hora)
  createdAt    DateTime @default(now()) @map("created_at")
  lastActivity DateTime @default(now()) @map("last_activity")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EvidenciaKPI {
  id         String @id @default(cuid())
  kpiId      String @map("kpi_id")
  empleadoId String @map("empleado_id")
  periodo    String // "2026-03"

  archivoUrl    String  @map("archivo_url")
  tipo          String // "imagen", "pdf", "video", "documento"
  nombre        String
  tamanio       Int?
  valorNumerico Float?  @map("valor_numerico")
  nota          String? @db.Text

  intento Int @default(1)

  status        String  @default("pendiente_revision")
  // "pendiente_revision" | "aprobada" | "rechazada"
  motivoRechazo String? @map("motivo_rechazo") @db.Text

  // Apelación
  apelacion          String?   @db.Text
  respuestaApelacion String?   @map("respuesta_apelacion") @db.Text
  fechaApelacion     DateTime? @map("fecha_apelacion")

  esFueraDeTiempo Boolean   @default(false) @map("es_fuera_de_tiempo")
  fechaSubida     DateTime  @default(now()) @map("fecha_subida")
  revisadoPor     String?   @map("revisado_por")
  fechaRevision   DateTime? @map("fecha_revision")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  kpi      KPI     @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  empleado User    @relation("EvidenciasKPIEmpleado", fields: [empleadoId], references: [id])
  revisor  User?   @relation("EvidenciasKPIRevisor", fields: [revisadoPor], references: [id])
  user     User?   @relation(fields: [userId], references: [id])
  userId   String?

  @@index([kpiId])
  @@index([empleadoId])
  @@index([periodo])
  @@index([status])
  @@map("evidencias_kpi")
}

model RevisorAsignado {
  id         String @id @default(cuid())
  empleadoId String @map("empleado_id") // Quien SUBE evidencias
  revisorId  String @map("revisor_id") // Quien las REVISA

  // Motivo / contexto de la excepción (para auditoría)
  motivo String? @db.Text

  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  empleado User @relation("EmpleadoRevisor", fields: [empleadoId], references: [id], onDelete: Cascade)
  revisor  User @relation("RevisorDeEmpleado", fields: [revisorId], references: [id], onDelete: Cascade)

  // Un empleado solo puede tener un revisor activo asignado a la vez
  @@unique([empleadoId, activo])
  @@index([empleadoId])
  @@index([revisorId])
  @@map("revisores_asignados")
}
