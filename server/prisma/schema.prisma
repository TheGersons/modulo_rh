generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  dni       String?  @unique
  email     String   @unique
  password  String
  nombre    String
  apellido  String
  role      String   @default("empleado")
  areaId    String?
  puesto    String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  area                    Area?          @relation("AreaEmpleados", fields: [areaId], references: [id])
  areaJefe                Area[]         @relation("AreaJefe")
  evaluacionesRecibidas   Evaluacion[]   @relation("EmpleadoEvaluado")
  evaluacionesCreadas     Evaluacion[]   @relation("Evaluador")
  ordenesTrabajoRecibidas OrdenTrabajo[] @relation("EmpleadoOrden")
  ordenesTrabajoCreadas   OrdenTrabajo[] @relation("CreadorOrden")
  revisionesRealizadas    RevisionJefe[]
  alertas                 Alerta[]       @relation("AlertasEmpleado")

  @@index([areaId])
  @@index([email])
  @@index([role])
}

model Area {
  id              String   @id @default(cuid())
  nombre          String   @unique
  descripcion     String?  @db.Text
  jefeId          String?
  promedioGlobal  Float    @default(0)
  totalKpis       Int      @default(0)
  kpisRojos       Int      @default(0)
  porcentajeRojos Float    @default(0)
  nivelRiesgo     String   @default("BAJO")
  ranking         Int      @default(0)
  comentarioRRHH  String?  @db.Text
  accionSugerida  String?  @db.Text
  responsable     String?
  activa          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  jefe      User?    @relation("AreaJefe", fields: [jefeId], references: [id])
  empleados User[]   @relation("AreaEmpleados")
  kpis      KPI[]
  alertas   Alerta[]

  @@index([jefeId])
  @@index([activa])
}

model KPI {
  id          String  @id @default(cuid())
  key         String  @unique
  area        String
  areaId      String
  puesto      String?
  indicador   String
  descripcion String? @db.Text

  // Configuración de cálculo automático
  tipoCalculo    String // "cumplimiento_simple", "tareas_completadas", "puntualidad", "calidad", "personalizado"
  formulaCalculo String @db.Text // JSON con parámetros del cálculo

  // Metas (opcional según tipo de cálculo)
  meta           Float?
  tolerancia     Float?
  umbralAmarillo Float?

  periodicidad String
  sentido      String // "Mayor es mejor", "Menor es mejor"
  unidad       String?
  orden        Int      @default(0)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  areaRelacion       Area                @relation(fields: [areaId], references: [id], onDelete: Cascade)
  ordenesTrabajoKPI  OrdenTrabajo[]
  evaluacionDetalles EvaluacionDetalle[]

  @@index([areaId])
  @@index([activo])
  @@index([puesto])
  @@index([tipoCalculo])
}

model OrdenTrabajo {
  id         String @id @default(cuid())
  kpiId      String
  empleadoId String
  creadorId  String

  titulo         String
  descripcion    String @db.Text
  cantidadTareas Int // Número de tareas/evidencias requeridas

  fechaInicio     DateTime  @default(now())
  fechaLimite     DateTime
  fechaCompletada DateTime?

  status String @default("pendiente") // "pendiente", "en_proceso", "completada", "vencida", "rechazada"

  // Cálculo automático
  tareasCompletadas Int    @default(0)
  progreso          Float  @default(0) // Porcentaje de avance
  resultadoFinal    Float? // Resultado calculado automáticamente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  kpi      KPI           @relation(fields: [kpiId], references: [id])
  empleado User          @relation("EmpleadoOrden", fields: [empleadoId], references: [id])
  creador  User          @relation("CreadorOrden", fields: [creadorId], references: [id])
  tareas   Tarea[]
  revision RevisionJefe?

  @@index([kpiId])
  @@index([empleadoId])
  @@index([creadorId])
  @@index([status])
  @@index([fechaLimite])
}

model Tarea {
  id             String @id @default(cuid())
  ordenTrabajoId String
  descripcion    String @db.Text
  orden          Int // Orden de la tarea (1, 2, 3...)

  completada      Boolean   @default(false)
  fechaCompletada DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  evidencias   Evidencia[]

  @@index([ordenTrabajoId])
  @@index([completada])
}

model Evidencia {
  id      String @id @default(cuid())
  tareaId String

  archivoUrl String // URL del archivo en cloud storage
  tipo       String // "imagen", "pdf", "video", "documento"
  nombre     String // Nombre original del archivo
  tamanio    Int? // Tamaño en bytes

  status        String  @default("pendiente_revision") // "pendiente_revision", "aprobada", "rechazada"
  motivoRechazo String? @db.Text

  fechaSubida DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  tarea Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@index([tareaId])
  @@index([status])
}

model RevisionJefe {
  id             String @id @default(cuid())
  ordenTrabajoId String @unique
  jefeId         String

  status        String // "aprobada", "rechazada"
  motivoRechazo String? @db.Text

  // Retroalimentación
  comentarios  String? @db.Text
  calificacion Int? // Opcional: calificación 1-5 si el KPI lo requiere

  fechaRevision DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  ordenTrabajo OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  jefe         User         @relation(fields: [jefeId], references: [id])

  @@index([ordenTrabajoId])
  @@index([jefeId])
  @@index([status])
}

model Evaluacion {
  id          String  @id @default(cuid())
  empleadoId  String
  evaluadorId String // Sistema (puede ser ID especial "SISTEMA")
  periodo     String
  tipoPeriodo String?
  anio        Int

  // Cálculo 100% automático
  calculadaAutomaticamente Boolean @default(true)
  promedioGeneral          Float?
  kpisRojos                Int     @default(0)
  porcentajeRojos          Float   @default(0)

  status       String    @default("borrador") // "borrador", "calculada", "cerrada"
  fechaCalculo DateTime?
  fechaCierre  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  empleado  User                @relation("EmpleadoEvaluado", fields: [empleadoId], references: [id])
  evaluador User                @relation("Evaluador", fields: [evaluadorId], references: [id])
  detalles  EvaluacionDetalle[]
  alertas   Alerta[]

  @@unique([empleadoId, periodo, anio])
  @@index([empleadoId])
  @@index([evaluadorId])
  @@index([status])
  @@index([anio])
}

model EvaluacionDetalle {
  id             String  @id @default(cuid())
  evaluacionId   String
  kpiId          String
  ordenTrabajoId String? // Referencia a la orden que generó este resultado

  // Resultados calculados automáticamente
  resultadoNumerico   Float
  resultadoPorcentaje Float?
  brechaVsMeta        Float?
  estado              String? // "verde", "amarillo", "rojo"

  // Metadata del cálculo
  formulaUtilizada String? @db.Text // JSON con los parámetros usados en el cálculo

  meta           Float?
  umbralAmarillo Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  evaluacion Evaluacion @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)
  kpi        KPI        @relation(fields: [kpiId], references: [id])

  @@index([evaluacionId])
  @@index([kpiId])
  @@index([ordenTrabajoId])
  @@index([estado])
}

model Alerta {
  id           String  @id @default(cuid())
  areaId       String
  empleadoId   String?
  evaluacionId String?

  tipo           String // "orden_vencida", "kpi_critico", "evidencia_rechazada", "carga_alta"
  nivel          String // "BAJO", "MEDIO", "ALTO"
  titulo         String
  descripcion    String  @db.Text
  accionSugerida String? @db.Text
  responsable    String?

  status          String    @default("activa") // "activa", "en_proceso", "resuelta"
  fechaDeteccion  DateTime  @default(now())
  fechaResolucion DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  area       Area        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  empleado   User?       @relation("AlertasEmpleado", fields: [empleadoId], references: [id], onDelete: SetNull)
  evaluacion Evaluacion? @relation(fields: [evaluacionId], references: [id], onDelete: SetNull)

  @@index([areaId])
  @@index([empleadoId])
  @@index([evaluacionId])
  @@index([status])
  @@index([nivel])
  @@index([tipo])
}
